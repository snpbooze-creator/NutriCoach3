rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Development rules ──────────────────────────────────────────────────
    // Any authenticated user can read and write all documents.
    // Sufficient for development and demo purposes.
    // Replace with the production rules below before going live.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

